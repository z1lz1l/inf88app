# ══════════════════════════════════════════════════
# 88inf — Environment Variables
# Copy this file to .env.local (Next.js app)
# Copy relevant vars to .env (server)
# NEVER commit either file to git
# ══════════════════════════════════════════════════

# ── Solana ─────────────────────────────────────────
# Token address — filled after running 01_create_token.ts
NEXT_PUBLIC_MINT_ADDRESS=

# Your merchant wallet (for receiving payments)
NEXT_PUBLIC_MERCHANT_WALLET=

# Solana RPC — free tier at helius.dev (faster than public)
# Sign up at helius.dev, create API key, paste URL here
NEXT_PUBLIC_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Firebase (Frontend — safe to expose) ───────────
# Get from Firebase console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase (Server — NEVER expose) ───────────────
# From Firebase console → Project Settings → Service accounts → Generate key
# Paste the entire JSON content as a single line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Privy ───────────────────────────────────────────
# From privy.io → Dashboard → App settings
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── Treasury (Server only — NEVER expose) ──────────
# The wallet that holds app_rewards tokens (26.4M 88INF)
# Paste as JSON array: [1,2,3,...]
TREASURY_PRIVATE_KEY=

# Deployer wallet private key (only needed for deployment scripts)
PRIVATE_KEY=

# ── Cron Security ───────────────────────────────────
# Random secret string — generate with: openssl rand -hex 32
CRON_SECRET=

# ── App Settings ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.88inf.com
ALLOWED_ORIGIN=https://app.88inf.com
PORT=3001

# ── ILS Exchange Rate ────────────────────────────────
# In production: fetch live from frankfurter.app (free API)
# https://api.frankfurter.app/latest?from=ILS&to=USD
# For now: 1 ILS ≈ 0.27 USD
NEXT_PUBLIC_ILS_TO_USD=0.27

# ══════════════════════════════════════════════════
# HOW TO GET EACH VALUE:
#
# MINT_ADDRESS       → Run 01_create_token.ts, copy output
# SOLANA_RPC         → helius.dev → free account → copy URL
# Firebase vars      → console.firebase.google.com → Your project
#                      → Project Settings → Your apps → Config
# FIREBASE_SERVICE_ACCOUNT → Same page → Service accounts tab
#                            → Generate new private key
# PRIVY_APP_ID       → privy.io → Create app → Settings
# TREASURY_PRIVATE_KEY → The wallet you sent app_rewards to in step 3
# CRON_SECRET        → run: openssl rand -hex 32
# ══════════════════════════════════════════════════
