# 88inf — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git — add it to .gitignore

# Your Solana wallet private key (as JSON array)
# Get from Phantom: Settings → Security → Export Private Key
PRIVATE_KEY=[1,2,3,...] 

# Token mint address (filled in after running 01_create_token.ts)
MINT_ADDRESS=

# Wallet addresses for fee collection
REWARDS_WALLET=
OPS_WALLET=
COMPANY_WALLET=
